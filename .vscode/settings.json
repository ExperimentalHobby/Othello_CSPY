{
	"files.exclude": {
		"**/bin": true,
		"**/obj": true,
		"**/__pycache__": true,
		"**/*.pyc": true,
		"src/Othello.Rust/target": true
	},
	"python.defaultInterpreterPath": "py",
	"editor.insertSpaces": false,
	"[python]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 4
	},
	"[csharp]": {
		"editor.tabSize": 4
	},
	"plantuml.server": "https://www.plantuml.com/plantuml",
	"plantuml.render": "PlantUMLServer"
}