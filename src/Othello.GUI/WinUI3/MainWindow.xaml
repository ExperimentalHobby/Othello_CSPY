<Window
    x:Class="Technopro.Othello.WinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Technopro.Othello.WinUI3"
    xmlns:conv="using:Technopro.Othello.WinUI3.Converters"
    Title="Othello (オセロ) - WinUI3">

    <!-- Background 未指定 = Mica/Acrylic（WindowBackdropHelper）が透けて見える。
         各パネルは個別に不透明な Background を持つため視認性への影響はない -->
    <Grid>
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            <conv:PlayerColorToBrushConverter x:Key="PlayerColorToBrushConverter"/>

            <!-- メニューボタン共通スタイル -->
            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#4a7c2f"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="5,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- ボタンのホバー・押下色テーマオーバーライド（黒反転防止）
                 Grid 配下のすべての Button に適用される -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5a8c3f"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#3a6c1f"/>
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
            <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="White"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>

            <!-- AI バッジ色（WPF 版 AppColors.xaml と同値） -->
            <SolidColorBrush x:Key="AiBadgeBackgroundBrush" Color="#1a1a2e"/>
            <SolidColorBrush x:Key="AiBadgeForegroundBrush" Color="#7ec8e3"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#1a3010" Height="50" Spacing="0">
            <!-- AI エンジン表示 -->
            <Border Background="{StaticResource AiBadgeBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="8,0,4,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding AiEngineLabel}" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AiBadgeForegroundBrush}" VerticalAlignment="Center"/>
            </Border>
            <Rectangle Width="2" Fill="#666666" Margin="4,5" VerticalAlignment="Stretch"/>
            <Button Content="新規ゲーム" Command="{Binding NewGameCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>
            <!-- CPU vs CPU 専用: 開始/一時停止（新規ゲームの直隣に配置） -->
            <Button Content="{Binding PauseButtonContent}"
                    Command="{Binding PauseCommand}"
                    Style="{StaticResource MenuButtonStyle}"
                    Visibility="{Binding IsCpuVsCpu, Converter={StaticResource BoolToVisConverter}}"/>
            <Button Content="戻す" Command="{Binding UndoCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>
            <ToggleButton Content="ヒント"
                          IsChecked="{Binding IsHintEnabled, Mode=TwoWay}"
                          Background="#4a7c2f" Foreground="White"
                          FontSize="12" Padding="10,5" Margin="5,0"
                          VerticalAlignment="Center"/>

            <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>
            <Button Content="棋譜を保存" Click="OnSaveKifu"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="棋譜を開く" Click="OnOpenKifu"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

            <!-- 対戦モード -->
            <TextBlock Text="対戦モード:" VerticalAlignment="Center" Margin="10,0,5,0"
                       Foreground="White" FontSize="12"/>
            <ComboBox Width="120" Margin="5,0" VerticalAlignment="Center" FontSize="12"
                      RequestedTheme="Light"
                      SelectedIndex="{Binding GameModeIndex, Mode=TwoWay}"
                      IsEnabled="{Binding IsSettingsEditable}">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                    <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                    <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                </ComboBox.Resources>
                <ComboBoxItem Content="人間 vs CPU"/>
                <ComboBoxItem Content="CPU vs CPU"/>
            </ComboBox>

            <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

            <!-- 人間 vs CPU 専用コントロール -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsHumanVsCpu, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="難易度:" VerticalAlignment="Center" Margin="10,0,5,0"
                           Foreground="White" FontSize="12"/>
                <ComboBox Width="110" Margin="5,0" VerticalAlignment="Center" FontSize="12"
                          RequestedTheme="Light"
                          SelectedIndex="{Binding DifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                        <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>

                <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

                <!-- 制限時間モード -->
                <ToggleButton Content="制限時間"
                              IsChecked="{Binding IsTimeLimitEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding IsTimeLimitEditable}"
                              Background="#4a7c2f" Foreground="White"
                              FontSize="12" Padding="10,5" Margin="5,0"
                              VerticalAlignment="Center"/>
                <TextBox x:Name="TimeLimitSecondsBox"
                         Width="50" Margin="4,0" VerticalAlignment="Center" FontSize="12"
                         Text="{Binding TimeLimitSeconds, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                         IsEnabled="{Binding IsTimeLimitEditable}"
                         LostFocus="OnTimeLimitSecondsLostFocus"
                         KeyDown="OnTimeLimitSecondsKeyDown"
                         RequestedTheme="Light"
                         TextAlignment="Center"/>
                <TextBlock Text="秒" VerticalAlignment="Center" Foreground="White" FontSize="12"/>
                <TextBlock Text=" 残り:" VerticalAlignment="Center" Foreground="White" FontSize="12"
                           Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisConverter}}"/>
                <TextBlock Text="{Binding RemainingSecondsText}"
                           VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Margin="2,0"
                           Foreground="White"
                           Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisConverter}}"/>

                <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

                <TextBlock Text="あなたの色:" VerticalAlignment="Center" Margin="10,0,5,0"
                           Foreground="White" FontSize="12"/>
                <ComboBox Width="120" Margin="5,0" VerticalAlignment="Center" FontSize="12"
                          RequestedTheme="Light"
                          SelectedIndex="{Binding HumanColorIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                        <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="黒（先手）"/>
                    <ComboBoxItem Content="白（後手）"/>
                </ComboBox>
            </StackPanel>

            <!-- CPU vs CPU 専用コントロール -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsCpuVsCpu, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="黒:" VerticalAlignment="Center" Margin="10,0,3,0"
                           Foreground="White" FontSize="12"/>
                <ComboBox Width="90" Margin="3,0" VerticalAlignment="Center" FontSize="12"
                          RequestedTheme="Light"
                          SelectedIndex="{Binding BlackDifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                        <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>
                <TextBlock Text="白:" VerticalAlignment="Center" Margin="8,0,3,0"
                           Foreground="White" FontSize="12"/>
                <ComboBox Width="90" Margin="3,0" VerticalAlignment="Center" FontSize="12"
                          RequestedTheme="Light"
                          SelectedIndex="{Binding WhiteDifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                        <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>

                <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="10,0,3,0"
                           Foreground="White" FontSize="12"/>
                <ComboBox Width="115" Margin="3,0" VerticalAlignment="Center" FontSize="12"
                          RequestedTheme="Light"
                          SelectedIndex="{Binding CpuVsCpuDelayIndex, Mode=TwoWay}">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                        <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                        <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                        <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="高速 (0.5秒)"/>
                    <ComboBoxItem Content="標準 (1秒)"/>
                    <ComboBoxItem Content="低速 (2秒)"/>
                    <ComboBoxItem Content="最遅 (3秒)"/>
                </ComboBox>

            </StackPanel>
        </StackPanel>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ボード: AI 思考中はヒットテストを無効化して誤クリックを防ぐ（WPF 版と対称） -->
            <Border Grid.Column="0" Margin="40" BorderBrush="Black" BorderThickness="4"
                    Background="#4a7c2f"
                    IsHitTestVisible="{Binding IsAIThinking, Converter={StaticResource InverseBoolConverter}}"
                    SizeChanged="OnBoardBorderSizeChanged">
                <ItemsRepeater x:Name="BoardRepeater"
                               ItemsSource="{Binding BoardSquares}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MaximumRowsOrColumns="8" Orientation="Horizontal"
                                           ItemsStretch="Fill"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button Background="#4a7c2f" BorderBrush="Black" BorderThickness="1"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                    Click="OnSquareClick">
                                <Viewbox Stretch="Uniform" Margin="4"
                                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Grid Width="100" Height="100">
                                        <Ellipse Fill="Yellow" Opacity="0.6" Width="62" Height="62"
                                                 Visibility="{Binding IsValidMove, Converter={StaticResource BoolToVisConverter}}"/>
                                        <Ellipse Fill="#6495ED" Opacity="0.75" Width="62" Height="62"
                                                 Visibility="{Binding IsHint, Converter={StaticResource BoolToVisConverter}}"/>
                                        <Ellipse Tag="Stone"
                                                 Fill="{Binding Piece, Converter={StaticResource PlayerColorToBrushConverter}}"
                                                 Stroke="#2a2a2a" StrokeThickness="2"
                                                 Width="88" Height="88"
                                                 Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisConverter}}"/>
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>

            <!-- サイドパネル -->
            <ScrollViewer Grid.Column="1" Margin="10">
                <StackPanel Spacing="10">
                    <!-- ゲーム状態 -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="5">
                            <TextBlock Text="ゲーム状態" FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="{Binding CurrentPlayerDisplay}" FontSize="13"
                                       Foreground="White" TextWrapping="Wrap"/>
                            <!-- 固定高で囲むことで Collapsed/Visible 切替時のレイアウトシフトを防ぐ -->
                            <Grid Height="16">
                                <TextBlock Text="AI が考え中..." FontSize="11" Foreground="Yellow"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsAIThinking, Converter={StaticResource BoolToVisConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- スコア -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="5">
                            <TextBlock Text="スコア" FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Fill="Black" Width="15" Height="15"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BlackScore}" FontSize="13"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Fill="White" Width="15" Height="15"
                                         VerticalAlignment="Center"
                                         Stroke="Black" StrokeThickness="1"/>
                                <TextBlock Text="{Binding WhiteScore}" FontSize="13"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- スコア推移グラフ -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="4">
                            <TextBlock Text="スコア推移" FontSize="13" FontWeight="Bold"
                                       Foreground="White"/>

                            <!-- 凡例 -->
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <Ellipse Width="8" Height="8" Fill="#222222" Stroke="#cccccc"
                                         StrokeThickness="1.5" VerticalAlignment="Center"/>
                                <TextBlock Text="黒" FontSize="9" Foreground="#cccccc"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Ellipse Width="8" Height="8" Fill="White" Stroke="White"
                                         StrokeThickness="1" VerticalAlignment="Center"/>
                                <TextBlock Text="白（破線）" FontSize="9" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- グラフ本体：Y軸ラベル + Canvas -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Y軸ラベル（石数） -->
                                <Grid Grid.Column="0">
                                    <TextBlock Text="64" FontSize="8" Foreground="#cccccc"
                                               VerticalAlignment="Top" HorizontalAlignment="Right"
                                               Margin="0,0,2,0"/>
                                    <TextBlock Text="石" FontSize="8" Foreground="#cccccc"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Margin="0,0,2,0"/>
                                    <TextBlock Text="0" FontSize="8" Foreground="#cccccc"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                               Margin="0,0,2,0"/>
                                </Grid>

                                <Canvas Grid.Column="1" x:Name="ScoreCanvas" Height="100"
                                        Background="#0d1f0a"
                                        SizeChanged="OnScoreCanvasSizeChanged">
                                    <Line x:Name="MidLine" Stroke="#555555" StrokeThickness="1"
                                          StrokeDashArray="4 4" Y1="0" Y2="0" X1="0" X2="0"/>
                                    <Polyline x:Name="BlackScoreLine" Stroke="#cccccc"
                                              StrokeThickness="2"/>
                                    <Polyline x:Name="WhiteScoreLine" Stroke="White"
                                              StrokeThickness="2" StrokeDashArray="5 3"/>
                                    <Line x:Name="CurrentMoveLine" Stroke="Yellow" StrokeThickness="1"
                                          Opacity="0.5" Y1="0" Y2="0" X1="0" X2="0"/>
                                </Canvas>
                            </Grid>

                            <!-- X軸ラベル（手数） -->
                            <TextBlock Text="手数 →" FontSize="8" Foreground="#cccccc"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- 棋力統計 -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="4" DataContext="{Binding Stats}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="棋力統計" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <Button Grid.Column="1" Content="リセット"
                                        Command="{Binding ResetCommand}"
                                        FontSize="10" Padding="6,2"
                                        Background="#2a3a2a" Foreground="#cccccc"/>
                            </Grid>

                            <!-- 難易度別テーブル -->
                            <Grid RowSpacing="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="42"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- ヘッダー -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="難易度" FontSize="10" Foreground="#aaaaaa"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="勝" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="負" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="引" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="勝率" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Right"/>

                                <!-- Beginner -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Beginner" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BeginnerWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BeginnerLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BeginnerDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding BeginnerWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Easy -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Easy" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EasyWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding EasyLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding EasyDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding EasyWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Normal -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Normal" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NormalWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding NormalLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding NormalDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding NormalWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Hard -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Hard" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HardWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding HardLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding HardDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding HardWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Expert -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Expert" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ExpertWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding ExpertLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding ExpertDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="4" Text="{Binding ExpertWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- 通算サマリー -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="通算:" FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding TotalGames}" FontSize="10" Foreground="#cccccc"/>
                                    <TextBlock Text="戦" FontSize="10" Foreground="#aaaaaa"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="連勝:" FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding CurrentStreak}" FontSize="10" Foreground="#88ff88"/>
                                    <TextBlock Text="(最高:" FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding MaxStreak}" FontSize="10" Foreground="#ffdd88"/>
                                    <TextBlock Text=")" FontSize="10" Foreground="#aaaaaa"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="最大石差:" FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding BestWinMargin}" FontSize="10" Foreground="#ffdd88"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ルール説明 -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="3">
                            <TextBlock Text="ルール" FontSize="13" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="• 黒と白が交互に石を置きます"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 敵の石を自分の石ではさむと反転します"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 置ける場所がない場合→パスします"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 両プレイヤーが連続でパス→ゲーム終了"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="#1a3010" Height="40">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                       FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
