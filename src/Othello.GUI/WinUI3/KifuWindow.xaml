<Window
    x:Class="Technopro.Othello.WinUI3.KifuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Technopro.Othello.WinUI3"
    xmlns:conv="using:Technopro.Othello.WinUI3.Converters"
    Title="棋譜再生">

    <Grid Background="#2d5016">
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:PlayerColorToBrushConverter x:Key="PlayerColorToBrushConverter"/>

            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#4a7c2f"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="4,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5a8c3f"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#3a6c1f"/>
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
            <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="White"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステータスバー（上） -->
        <StackPanel Grid.Row="0" Background="#1a3010" Height="40" Orientation="Horizontal">
            <TextBlock x:Name="StatusLabel" Text="{Binding StatusMessage}"
                       Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>

        <!-- ボード -->
        <Border x:Name="BoardBorder" Grid.Row="1" Margin="30,20"
                BorderBrush="Black" BorderThickness="4"
                Background="#4a7c2f"
                SizeChanged="OnBoardSizeChanged">
            <ItemsRepeater x:Name="BoardRepeater" ItemsSource="{Binding BoardSquares}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MaximumRowsOrColumns="8"
                                       Orientation="Horizontal"
                                       ItemsStretch="Fill"
                                       MinItemWidth="80"
                                       MinItemHeight="80"/>
                </ItemsRepeater.Layout>
                <DataTemplate>
                    <Border Background="#4a7c2f" BorderBrush="Black" BorderThickness="1">
                        <Ellipse Fill="{Binding Piece, Converter={StaticResource PlayerColorToBrushConverter}}"
                                 Stroke="#2a2a2a" StrokeThickness="2"
                                 Width="78" Height="78" Margin="4"
                                 Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisConverter}}"/>
                    </Border>
                </DataTemplate>
            </ItemsRepeater>
        </Border>

        <!-- ナビゲーションバー -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8">
            <Button Content="|◀" Command="{Binding GoToStartCommand}"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="◀" Command="{Binding StepBackCommand}"
                    Style="{StaticResource NavButtonStyle}"/>
            <TextBlock Foreground="White" FontSize="14" Margin="10,0" VerticalAlignment="Center">
                <Run Text="{Binding CurrentMove}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalMoves}"/>
            </TextBlock>
            <Button Content="▶" Command="{Binding StepForwardCommand}"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="▶|" Command="{Binding GoToEndCommand}"
                    Style="{StaticResource NavButtonStyle}"/>
        </StackPanel>

        <!-- 棋譜情報バー（下） -->
        <StackPanel Grid.Row="3" Background="#1a3010" Height="36" Orientation="Horizontal">
            <TextBlock Text="{Binding KifuInfo}" Foreground="White"
                       FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>
