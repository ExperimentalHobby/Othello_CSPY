<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- メニューバーボタン -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Background"        Value="{StaticResource BoardGreenBrush}"/>
        <Setter Property="Foreground"        Value="{StaticResource WhiteTextBrush}"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Padding"           Value="10,5"/>
        <Setter Property="Margin"            Value="5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- メニューバー ComboBox -->
    <Style x:Key="MenuComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"        Value="{StaticResource BoardGreenBrush}"/>
        <Setter Property="Foreground"        Value="{StaticResource BlackTextBrush}"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BorderDarkGreenBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="MenuComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BlackTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource WhiteTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Background="{TemplateBinding Background}" Padding="5">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource BlackTextBrush}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource ComboBoxItemHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- サイドパネル枠 -->
    <Style x:Key="SidebarPanelStyle" TargetType="Border">
        <Setter Property="Background"    Value="{StaticResource MenuDarkGreenBrush}"/>
        <Setter Property="CornerRadius"  Value="5"/>
        <Setter Property="Margin"        Value="0,0,0,10"/>
    </Style>

</ResourceDictionary>
