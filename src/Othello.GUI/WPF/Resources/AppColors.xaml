<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Green Theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"    Color="#2d5016"/>
    <SolidColorBrush x:Key="MenuDarkGreenBrush"       Color="#1a3010"/>
    <SolidColorBrush x:Key="BoardGreenBrush"          Color="#4a7c2f"/>
    <SolidColorBrush x:Key="ButtonHoverGreenBrush"    Color="#5a8c3f"/>
    <SolidColorBrush x:Key="BorderDarkGreenBrush"     Color="#2a5a1f"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush"   Color="#e8f5e9"/>

    <!-- Text / Misc -->
    <SolidColorBrush x:Key="WhiteTextBrush"           Color="White"/>
    <SolidColorBrush x:Key="BlackTextBrush"           Color="Black"/>
    <SolidColorBrush x:Key="ValidMoveHighlightBrush"  Color="Yellow"/>
    <SolidColorBrush x:Key="SeparatorBrush"           Color="#666666"/>

    <!-- AI Badge -->
    <SolidColorBrush x:Key="AiBadgeBackgroundBrush"   Color="#1a1a2e"/>
    <SolidColorBrush x:Key="AiBadgeForegroundBrush"   Color="#7ec8e3"/>

</ResourceDictionary>
