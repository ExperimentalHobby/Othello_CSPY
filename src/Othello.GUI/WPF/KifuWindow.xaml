<Window x:Class="Technopro.Othello.WPF.KifuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Technopro.Othello.WPF.Converters"
        Title="棋譜再生" Height="800" Width="800"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource WhiteTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:PlayerColorToBrushConverter x:Key="PlayerColorToBrushConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 棋譜情報バー -->
        <StackPanel Grid.Row="0" Background="{StaticResource MenuDarkGreenBrush}"
                    Orientation="Horizontal" Height="40" Margin="0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       Foreground="{StaticResource WhiteTextBrush}" FontSize="12" Margin="12,0"/>
        </StackPanel>

        <!-- ボード -->
        <Border Grid.Row="1" Margin="30,20" BorderBrush="Black" BorderThickness="4"
                Background="{StaticResource BoardGreenBrush}">
            <ItemsControl ItemsSource="{Binding BoardSquares}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="8" Rows="8" Margin="0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BoardGreenBrush}"
                                BorderBrush="Black" BorderThickness="1">
                            <Ellipse Fill="{Binding Piece, Converter={StaticResource PlayerColorToBrushConverter}}"
                                     Stroke="#2a2a2a" StrokeThickness="2"
                                     Width="78" Height="78"
                                     Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisConverter}}"
                                     Margin="4"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ナビゲーションバー -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,8">
            <Button Content="|◀" Command="{Binding GoToStartCommand}"
                    Style="{StaticResource ActionButtonStyle}" Width="46"/>
            <Button Content="◀" Command="{Binding StepBackCommand}"
                    Style="{StaticResource ActionButtonStyle}" Width="46"/>
            <TextBlock Text="{Binding CurrentMove}" VerticalAlignment="Center"
                       FontSize="14" Foreground="{StaticResource WhiteTextBrush}" Margin="8,0"/>
            <TextBlock Text=" / " VerticalAlignment="Center"
                       FontSize="14" Foreground="{StaticResource WhiteTextBrush}"/>
            <TextBlock Text="{Binding TotalMoves}" VerticalAlignment="Center"
                       FontSize="14" Foreground="{StaticResource WhiteTextBrush}" Margin="0,0,8,0"/>
            <Button Content="▶" Command="{Binding StepForwardCommand}"
                    Style="{StaticResource ActionButtonStyle}" Width="46"/>
            <Button Content="▶|" Command="{Binding GoToEndCommand}"
                    Style="{StaticResource ActionButtonStyle}" Width="46"/>
        </StackPanel>

        <!-- ステータスバー -->
        <StackPanel Grid.Row="3" Background="{StaticResource MenuDarkGreenBrush}" Height="36">
            <TextBlock Text="{Binding KifuInfo}" Foreground="{StaticResource WhiteTextBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>
