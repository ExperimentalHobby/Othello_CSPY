<Window x:Class="Technopro.Othello.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Technopro.Othello.WPF.Converters"
        Title="Othello (オセロ) - WPF" Height="1000" Width="1350"
        Background="{StaticResource WindowBackgroundBrush}" Foreground="{StaticResource WhiteTextBrush}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <conv:PlayerColorToBrushConverter x:Key="PlayerColorToBrushConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Background="{StaticResource MenuDarkGreenBrush}" Height="50">
            <!-- AI エンジン表示 -->
            <Border Background="{StaticResource AiBadgeBackgroundBrush}"
                    CornerRadius="4" Padding="8,4" Margin="8,0,4,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding AiEngineLabel}" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AiBadgeForegroundBrush}" VerticalAlignment="Center"/>
            </Border>
            <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="4,0"/>
            <Button Content="新規ゲーム" Command="{Binding NewGameCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>
            <!-- CPU vs CPU 専用: 開始/一時停止（新規ゲームの直隣に配置） -->
            <Button Content="{Binding PauseButtonContent}"
                    Command="{Binding PauseCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Visibility="{Binding IsCpuVsCpu, Converter={StaticResource BoolToVisConverter}}"/>
            <Button Content="戻す" Command="{Binding UndoCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>
            <ToggleButton Content="ヒント"
                          IsChecked="{Binding IsHintEnabled, Mode=TwoWay}"
                          Style="{StaticResource ActionToggleButtonStyle}"/>

            <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>
            <Button Content="棋譜を保存" Click="OnSaveKifu"
                    Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="棋譜を開く" Click="OnOpenKifu"
                    Style="{StaticResource ActionButtonStyle}"/>

            <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>

            <!-- 対戦モード -->
            <TextBlock Text="対戦モード:" VerticalAlignment="Center" Margin="5,0" FontSize="12"/>
            <ComboBox Width="110" Margin="4,0" VerticalAlignment="Center" FontSize="12"
                      Style="{StaticResource MenuComboBoxStyle}"
                      ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                      SelectedIndex="{Binding GameModeIndex, Mode=TwoWay}"
                      IsEnabled="{Binding IsSettingsEditable}">
                <ComboBoxItem Content="人間 vs CPU"/>
                <ComboBoxItem Content="CPU vs CPU"/>
            </ComboBox>

            <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>

            <!-- 人間 vs CPU 専用コントロール -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsHumanVsCpu, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="難易度:" VerticalAlignment="Center" Margin="5,0" FontSize="12"/>
                <ComboBox Width="100" Margin="4,0" VerticalAlignment="Center" FontSize="12"
                          Style="{StaticResource MenuComboBoxStyle}"
                          ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                          SelectedIndex="{Binding DifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>

                <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>

                <!-- 制限時間モード -->
                <ToggleButton Content="制限時間"
                              IsChecked="{Binding IsTimeLimitEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding IsTimeLimitEditable}"
                              Style="{StaticResource ActionToggleButtonStyle}"/>
                <TextBox x:Name="TimeLimitSecondsBox"
                         Width="50" Margin="4,0" VerticalAlignment="Center" FontSize="12"
                         Text="{Binding TimeLimitSeconds, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                         IsEnabled="{Binding IsTimeLimitEditable}"
                         LostFocus="OnTimeLimitSecondsLostFocus"
                         KeyDown="OnTimeLimitSecondsKeyDown"
                         HorizontalContentAlignment="Center"/>
                <TextBlock Text="秒" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Text=" 残り:" VerticalAlignment="Center" FontSize="12"
                           Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisConverter}}"/>
                <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Margin="2,0"
                           Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}秒">
                            <Binding Path="RemainingSeconds"/>
                        </MultiBinding>
                    </TextBlock.Text>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTimerWarning}" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>

                <TextBlock Text="あなたの色:" VerticalAlignment="Center" Margin="5,0" FontSize="12"/>
                <ComboBox Width="100" Margin="4,0" VerticalAlignment="Center" FontSize="12"
                          Style="{StaticResource MenuComboBoxStyle}"
                          ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                          SelectedIndex="{Binding HumanColorIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBoxItem Content="黒（先手）"/>
                    <ComboBoxItem Content="白（後手）"/>
                </ComboBox>
            </StackPanel>

            <!-- CPU vs CPU 専用コントロール -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsCpuVsCpu, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="黒:" VerticalAlignment="Center" Margin="5,0,3,0" FontSize="12"/>
                <ComboBox Width="90" Margin="3,4" VerticalAlignment="Center" FontSize="12"
                          Style="{StaticResource MenuComboBoxStyle}"
                          ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                          SelectedIndex="{Binding BlackDifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>
                <TextBlock Text="白:" VerticalAlignment="Center" Margin="5,0,3,0" FontSize="12"/>
                <ComboBox Width="90" Margin="3,4" VerticalAlignment="Center" FontSize="12"
                          Style="{StaticResource MenuComboBoxStyle}"
                          ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                          SelectedIndex="{Binding WhiteDifficultyIndex, Mode=TwoWay}"
                          IsEnabled="{Binding IsSettingsEditable}">
                    <ComboBoxItem Content="ビギナー"/>
                    <ComboBoxItem Content="イージー"/>
                    <ComboBoxItem Content="ノーマル"/>
                    <ComboBoxItem Content="ハード"/>
                    <ComboBoxItem Content="エキスパート"/>
                </ComboBox>

                <Separator Width="2" Background="{StaticResource SeparatorBrush}" Margin="5,0"/>

                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="5,0,3,0" FontSize="12"/>
                <ComboBox Width="115" Margin="3,5" VerticalAlignment="Center" FontSize="12"
                          Style="{StaticResource MenuComboBoxStyle}"
                          ItemContainerStyle="{StaticResource MenuComboBoxItemStyle}"
                          SelectedIndex="{Binding CpuVsCpuDelayIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="高速 (0.5秒)"/>
                    <ComboBoxItem Content="標準 (1秒)"/>
                    <ComboBoxItem Content="低速 (2秒)"/>
                    <ComboBoxItem Content="最遅 (3秒)"/>
                </ComboBox>

            </StackPanel>
        </StackPanel>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ボード -->
            <Border Grid.Column="0" Margin="40" BorderBrush="Black" BorderThickness="4"
                    Background="{StaticResource BoardGreenBrush}" Padding="0">
                <ItemsControl ItemsSource="{Binding BoardSquares}"
                              IsHitTestVisible="{Binding IsAIThinking, Converter={StaticResource InverseBoolConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8" Rows="8" Margin="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0" Background="{StaticResource BoardGreenBrush}"
                                    BorderBrush="Black" BorderThickness="1"
                                    Padding="0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.SquareClickedCommand}"
                                    CommandParameter="{Binding Position}">
                                <Grid Background="{StaticResource BoardGreenBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Ellipse Fill="{StaticResource ValidMoveHighlightBrush}" Opacity="0.6" Width="55" Height="55"
                                             Visibility="{Binding IsValidMove, Converter={StaticResource BoolToVisConverter}}"/>
                                    <Ellipse Fill="{StaticResource HintHighlightBrush}" Opacity="0.75" Width="55" Height="55"
                                             Visibility="{Binding IsHint, Converter={StaticResource BoolToVisConverter}}"/>
                                    <Ellipse Fill="{Binding Piece, Converter={StaticResource PlayerColorToBrushConverter}}" Stroke="#2a2a2a" StrokeThickness="2"
                                             Width="78" Height="78"
                                             RenderTransformOrigin="0.5,0.5"
                                             Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisConverter}}">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBeingFlipped}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                        From="1" To="0" Duration="0:0:0.15"
                                                                        AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- サイドパネル -->
            <ScrollViewer Grid.Column="1" Margin="10" VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <!-- ゲーム状態 -->
                    <Border Style="{StaticResource SidebarPanelStyle}">
                        <StackPanel Margin="10">
                            <TextBlock Text="ゲーム状態" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding CurrentPlayerDisplay}" FontSize="13" Margin="0,0,0,5" TextWrapping="Wrap"/>
                            <!-- 固定高で囲むことで Collapsed/Visible 切替時のレイアウトシフトを防ぐ（WinUI3版と同じ対応） -->
                            <Grid Height="30">
                                <TextBlock Text="AI が考え中..." FontSize="11" Foreground="Yellow"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsAIThinking, Converter={StaticResource BoolToVisConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- スコア -->
                    <Border Style="{StaticResource SidebarPanelStyle}">
                        <StackPanel Margin="10">
                            <TextBlock Text="スコア" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Ellipse Fill="Black" Width="15" Height="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BlackScore}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Fill="White" Width="15" Height="15" Margin="0,0,10,0"
                                         VerticalAlignment="Center" Stroke="Black" StrokeThickness="1"/>
                                <TextBlock Text="{Binding WhiteScore}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- スコア推移グラフ -->
                    <Border Style="{StaticResource SidebarPanelStyle}">
                        <Expander Header="スコア推移" IsExpanded="True"
                                  Foreground="{StaticResource WhiteTextBrush}">
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 凡例 -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="8" Height="8" Fill="#222222" Stroke="#cccccc"
                                             StrokeThickness="1.5" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="黒" FontSize="9" Foreground="#cccccc"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Ellipse Width="8" Height="8" Fill="White" Stroke="White"
                                             StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="白（破線）" FontSize="9" Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- グラフ本体：Y軸ラベル + Canvas -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Y軸ラベル（石数） -->
                                    <Grid Grid.Column="0">
                                        <TextBlock Text="64" FontSize="8" Foreground="#cccccc"
                                                   VerticalAlignment="Top" HorizontalAlignment="Right"
                                                   Margin="0,0,2,0"/>
                                        <TextBlock Text="石" FontSize="8" Foreground="#cccccc"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Margin="0,0,2,0"/>
                                        <TextBlock Text="0" FontSize="8" Foreground="#cccccc"
                                                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                   Margin="0,0,2,0"/>
                                    </Grid>

                                    <Canvas Grid.Column="1" x:Name="ScoreCanvas" Height="100"
                                            Background="#0d1f0a" ClipToBounds="True"
                                            SizeChanged="OnScoreCanvasSizeChanged">
                                        <Line x:Name="MidLine" Stroke="#555555" StrokeThickness="1"
                                              StrokeDashArray="4,4" Y1="0" Y2="0" X1="0" X2="0"/>
                                        <Polyline x:Name="BlackScoreLine" Stroke="#cccccc" StrokeThickness="2"
                                                  StrokeLineJoin="Round"/>
                                        <Polyline x:Name="WhiteScoreLine" Stroke="White" StrokeThickness="2"
                                                  StrokeDashArray="5,3" StrokeLineJoin="Round"/>
                                        <Line x:Name="CurrentMoveLine" Stroke="Yellow" StrokeThickness="1"
                                              Opacity="0.5" Y1="0" Y2="0" X1="0" X2="0"/>
                                    </Canvas>
                                </Grid>

                                <!-- X軸ラベル（手数） -->
                                <TextBlock Grid.Row="2" Text="手数 →" FontSize="8" Foreground="#cccccc"
                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </Grid>
                        </Expander>
                    </Border>

                    <!-- 棋力統計 -->
                    <Border Style="{StaticResource SidebarPanelStyle}">
                        <StackPanel Margin="10" DataContext="{Binding Stats}">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="棋力統計" FontSize="13" FontWeight="Bold"/>
                                <Button DockPanel.Dock="Right" Content="リセット"
                                        Command="{Binding ResetCommand}"
                                        FontSize="10" Padding="6,2"
                                        Background="#2a3a2a" Foreground="#cccccc"
                                        BorderBrush="#3a5a3a"/>
                            </DockPanel>

                            <!-- 難易度別テーブル -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- ヘッダー -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="難易度" FontSize="10" Foreground="#aaaaaa"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="勝" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="負" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="引" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="勝率" FontSize="10" Foreground="#aaaaaa" HorizontalAlignment="Right"/>

                                <!-- Beginner -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Beginner" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BeginnerWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BeginnerLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BeginnerDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding BeginnerWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Easy -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Easy" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EasyWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding EasyLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding EasyDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding EasyWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Normal -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Normal" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NormalWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding NormalLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding NormalDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding NormalWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Hard -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Hard" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HardWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding HardLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding HardDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding HardWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>

                                <!-- Expert -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Expert" FontSize="11" Foreground="#cccccc"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ExpertWins}" FontSize="11" Foreground="#88ff88" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding ExpertLosses}" FontSize="11" Foreground="#ff8888" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding ExpertDraws}" FontSize="11" Foreground="#cccccc" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="4" Text="{Binding ExpertWinRate}" FontSize="11" Foreground="#ffdd88" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- 通算サマリー -->
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="通算: " FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding TotalGames}" FontSize="10" Foreground="#cccccc"/>
                                    <TextBlock Text=" 戦" FontSize="10" Foreground="#aaaaaa"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="連勝: " FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding CurrentStreak}" FontSize="10" Foreground="#88ff88"/>
                                    <TextBlock Text=" (最高: " FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding MaxStreak}" FontSize="10" Foreground="#ffdd88"/>
                                    <TextBlock Text=")" FontSize="10" Foreground="#aaaaaa"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="最大石差: " FontSize="10" Foreground="#aaaaaa"/>
                                    <TextBlock Text="{Binding BestWinMargin}" FontSize="10" Foreground="#ffdd88"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ルール説明 -->
                    <Border Style="{StaticResource SidebarPanelStyle}">
                        <StackPanel Margin="10">
                            <TextBlock Text="ルール" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="• 黒と白が交互に石を置きます" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,3"/>
                            <TextBlock Text="• 敵の石を自分の石ではさむと反転します" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,3"/>
                            <TextBlock Text="• 置ける場所がない場合→パスします" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,3"/>
                            <TextBlock Text="• 両プレイヤーが連続でパス→ゲーム終了" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ステータスバー -->
        <StackPanel Grid.Row="2" Background="{StaticResource MenuDarkGreenBrush}" Height="40">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource WhiteTextBrush}"
                       FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>
