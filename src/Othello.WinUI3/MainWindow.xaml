<Window
    x:Class="Technopro.Othello.WinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Technopro.Othello.WinUI3"
    xmlns:conv="using:Technopro.Othello.WinUI3.Converters"
    Title="Othello (オセロ) - Python AI">

    <Grid Background="#2d5016">
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:PlayerColorToBrushConverter x:Key="PlayerColorToBrushConverter"/>

            <!-- メニューボタン共通スタイル -->
            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#4a7c2f"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="5,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- ボタンのホバー・押下色テーマオーバーライド（黒反転防止）
                 Grid 配下のすべての Button に適用される -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5a8c3f"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#3a6c1f"/>
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
            <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="White"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#1a3010" Height="50" Spacing="0">
            <Button Content="新規ゲーム" Command="{Binding NewGameCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="戻す" Command="{Binding UndoCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

            <TextBlock Text="難易度:" VerticalAlignment="Center" Margin="10,0,5,0"
                       Foreground="White" FontSize="12"/>
            <!-- RequestedTheme="Light": ダーク背景でも ComboBox が見えるようライトテーマで描画 -->
            <ComboBox Width="110" Margin="5,0" VerticalAlignment="Center" FontSize="12"
                      RequestedTheme="Light"
                      SelectedIndex="{Binding DifficultyIndex, Mode=TwoWay}"
                      IsEnabled="{Binding IsSettingsEditable}">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                    <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                    <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                </ComboBox.Resources>
                <ComboBoxItem Content="イージー"/>
                <ComboBoxItem Content="ノーマル"/>
                <ComboBoxItem Content="ハード"/>
            </ComboBox>

            <Rectangle Width="2" Fill="#666666" Margin="10,5" VerticalAlignment="Stretch"/>

            <TextBlock Text="あなたの色:" VerticalAlignment="Center" Margin="10,0,5,0"
                       Foreground="White" FontSize="12"/>
            <ComboBox Width="120" Margin="5,0" VerticalAlignment="Center" FontSize="12"
                      RequestedTheme="Light"
                      SelectedIndex="{Binding HumanColorIndex, Mode=TwoWay}"
                      IsEnabled="{Binding IsSettingsEditable}">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="ComboBoxBackground"             Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"  Color="#f0f0f0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPressed"      Color="#e0e0e0"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"     Color="#e8e8e8"/>
                    <SolidColorBrush x:Key="ComboBoxDropDownBackground"     Color="White"/>
                    <SolidColorBrush x:Key="ComboBoxForeground"             Color="Black"/>
                    <SolidColorBrush x:Key="ComboBoxForegroundDisabled"     Color="#505050"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"    Color="#b0b0b0"/>
                </ComboBox.Resources>
                <ComboBoxItem Content="黒（先手）"/>
                <ComboBoxItem Content="白（後手）"/>
            </ComboBox>
        </StackPanel>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ボード -->
            <Border Grid.Column="0" Margin="40" BorderBrush="Black" BorderThickness="4"
                    Background="#4a7c2f"
                    SizeChanged="OnBoardBorderSizeChanged">
                <ItemsRepeater x:Name="BoardRepeater"
                               ItemsSource="{Binding BoardSquares}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MaximumRowsOrColumns="8" Orientation="Horizontal"
                                           MinItemWidth="110" MinItemHeight="110"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button Background="#4a7c2f" BorderBrush="Black" BorderThickness="1"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Click="OnSquareClick">
                                <Grid>
                                    <Ellipse Fill="Yellow" Opacity="0.6" Width="60" Height="60"
                                             Visibility="{Binding IsValidMove, Converter={StaticResource BoolToVisConverter}}"/>
                                    <Ellipse Fill="{Binding Piece, Converter={StaticResource PlayerColorToBrushConverter}}"
                                             Stroke="#2a2a2a" StrokeThickness="2"
                                             Width="85" Height="85"
                                             Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisConverter}}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>

            <!-- サイドパネル -->
            <ScrollViewer Grid.Column="1" Margin="10">
                <StackPanel Spacing="10">
                    <!-- ゲーム状態 -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="5">
                            <TextBlock Text="ゲーム状態" FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="{Binding CurrentPlayerDisplay}" FontSize="13"
                                       Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="AI が考え中..." FontSize="11" Foreground="Yellow"
                                       Visibility="{Binding IsAIThinking, Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- スコア -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="5">
                            <TextBlock Text="スコア" FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Fill="Black" Width="15" Height="15"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BlackScore}" FontSize="13"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Fill="White" Width="15" Height="15"
                                         VerticalAlignment="Center"
                                         Stroke="Black" StrokeThickness="1"/>
                                <TextBlock Text="{Binding WhiteScore}" FontSize="13"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ルール説明 -->
                    <Border Background="#1a3010" CornerRadius="5">
                        <StackPanel Margin="10" Spacing="3">
                            <TextBlock Text="ルール" FontSize="13" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="• 黒と白が交互に石を置きます"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 敵の石を自分の石ではさむと反転します"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 置ける場所がない場合→パスします"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                            <TextBlock Text="• 両プレイヤーが連続でパス→ゲーム終了"
                                       TextWrapping="Wrap" FontSize="11" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="#1a3010" Height="40">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                       FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
